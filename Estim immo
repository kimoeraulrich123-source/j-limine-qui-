<div class="result-overlay" id="resultOv"><div class="result-label">💰 Le vrai loyer est...</div><div class="result-price-big" id="rPrice">—</div><div class="result-grid" id="rGrid"></div><div class="result-continue"><button class="tbtn" id="btnNext">Manche suivante →</button></div></div>
<div class="final-overlay" id="finalOv"><div class="confetti-wrap" id="confWrap"></div><div class="final-trophy">🏆</div><div class="final-title" id="fTitle">—</div><div class="final-sub" id="fSub">—</div><div class="podium" id="podium"></div><div id="fExtra" style="display:flex;flex-direction:column;gap:8px;max-width:400px;width:100%"></div><div style="margin-top:16px;opacity:0;animation:su .4s ease 2s forwards"><button class="tbtn" onclick="backToMenu()">← Retour au menu</button></div></div>

<script>
"use strict";
const $=id=>document.getElementById(id);
const esc=s=>String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;');
const shuffle=a=>{const b=[...a];for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];}return b;};
const COLORS=['#7c3aed','#06b6d4','#10b981','#f59e0b','#ef4444','#ec4899','#8b5cf6','#14b8a6'];
const avC=n=>COLORS[(n||'a').charCodeAt(0)%COLORS.length];
const avI=n=>(n||'?')[0].toUpperCase();
const ROUNDS=6,TIMER=30;

// ══ PROPORTIONAL SCORING ══
// 0% écart = 1000 pts, 10% = 700, 25% = 400, 50%+ = 0
function calcPoints(guess,real){
  if(real<=0)return 0;
  const pctOff=Math.abs(guess-real)/real;
  if(pctOff>=0.5)return 0;
  // Linear from 1000 (0%) to 0 (50%)
  return Math.round(1000*(1-pctOff*2));
}

// ══ PHOTO KEYWORDS for Unsplash ══
const PHOTO_KEYS=['modern+apartment+interior','kitchen+apartment','living+room+interior','bedroom+apartment+interior','bathroom+modern','apartment+balcony+view','french+apartment','studio+apartment','cozy+living+room','dining+room+apartment'];
function getPhotos(){
  const picked=shuffle(PHOTO_KEYS).slice(0,3);
  return picked.map((k,i)=>`https://source.unsplash.com/1200x800/?${k}&sig=${Date.now()+i}`);
}

// ══ AI LISTING GENERATION ══
const CITIES_POOL=[
  {city:"Paris 11e – Bastille",region:"Île-de-France",lat:48.8534,lng:2.3706},
