<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Estim'Immo — Game Verse</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --orange:#ff6b2b;--orange2:#ff8f59;--orange-bg:rgba(255,107,43,.15);
  --green:#22c55e;--green2:#4ade80;
  --red:#ef4444;--red2:#f87171;
  --blue:#3b82f6;--blue2:#60a5fa;
  --gold:#fbbf24;--gold2:#fcd34d;
  --dark:#0f0f0f;--dark2:#1a1a1a;--dark3:#252525;
  --white:#fff;--gray:#888;--gray2:#555;--gray3:#333;
  --radius:16px;
}
html,body{height:100%;overflow:hidden}
body{font-family:'Outfit',sans-serif;background:var(--dark);color:var(--white)}

/* ══ MENU ══ */
#menuScreen{position:fixed;inset:0;z-index:100;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(135deg,#1a0a00,#0f0f0f 40%,#0a0f1a);gap:20px;padding:20px}
.menu-logo{font-size:4rem;animation:bounce 2s ease infinite}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.menu-title{font-weight:900;font-size:clamp(2rem,6vw,3.5rem);background:linear-gradient(135deg,var(--orange),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;text-align:center}
.menu-sub{font-size:1rem;color:var(--gray);text-align:center;max-width:520px;line-height:1.6}
.menu-modes{display:flex;gap:16px;margin-top:12px;flex-wrap:wrap;justify-content:center}
.menu-mode{padding:20px 28px;border-radius:var(--radius);cursor:pointer;transition:all .2s;border:2px solid var(--gray3);background:var(--dark2);display:flex;flex-direction:column;align-items:center;gap:8px;min-width:180px}
.menu-mode:hover{transform:translateY(-4px);border-color:var(--orange);box-shadow:0 12px 40px rgba(255,107,43,.2)}
.menu-mode-icon{font-size:2rem}
.menu-mode-title{font-weight:800;font-size:1.1rem}
.menu-mode-sub{font-size:.78rem;color:var(--gray);text-align:center}

/* ══ SETUP ══ */
#setupScreen{position:fixed;inset:0;z-index:90;display:none;flex-direction:column;align-items:center;justify-content:center;background:var(--dark);padding:20px;gap:16px}
#setupScreen.active{display:flex}
.setup-box{background:var(--dark2);border:1px solid var(--gray3);border-radius:var(--radius);padding:28px;max-width:420px;width:100%}
.setup-title{font-weight:900;font-size:1.5rem;margin-bottom:4px}
.setup-sub{font-size:.85rem;color:var(--gray);margin-bottom:18px}
.setup-input-row{display:flex;gap:8px;margin-bottom:12px}
.setup-input{flex:1;padding:12px 16px;border-radius:12px;border:2px solid var(--gray3);background:var(--dark3);color:white;font-family:'Outfit',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s}
.setup-input:focus{border-color:var(--orange)}
.setup-input::placeholder{color:var(--gray2)}
.sbtn{padding:12px 20px;border-radius:12px;border:none;font-family:'Outfit',sans-serif;font-weight:700;font-size:.9rem;cursor:pointer;transition:all .2s}
.sbtn:hover{transform:translateY(-2px)}
.sbtn-o{background:var(--orange);color:white}
.sbtn-g{background:var(--dark3);color:var(--gray);border:1px solid var(--gray3)}
.sbtn-big{width:100%;padding:16px;font-size:1rem;font-weight:900;margin-top:10px}
.player-chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;min-height:40px}
.player-chip{display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:999px;background:var(--orange-bg);border:1px solid rgba(255,107,43,.3);font-size:.82rem;font-weight:600}
.player-chip .x{cursor:pointer;color:var(--red2);font-weight:900}

/* ══ GAME ══ */
#gameScreen{position:fixed;inset:0;display:none;flex-direction:column;background:var(--dark)}
#gameScreen.active{display:flex}
.top-bar{display:flex;align-items:center;gap:12px;padding:8px 16px;background:var(--dark2);border-bottom:1px solid var(--gray3);flex-shrink:0;z-index:10}
.score-pill{background:var(--red);color:white;padding:6px 16px;border-radius:999px;font-family:'JetBrains Mono',monospace;font-weight:700;font-size:.9rem;white-space:nowrap}
.timer-wrap{flex:1;height:32px;background:var(--dark3);border-radius:999px;overflow:hidden;position:relative;border:2px solid var(--gray3)}
.timer-fill{height:100%;background:linear-gradient(90deg,var(--green),var(--green2));border-radius:999px;transition:width .15s linear}
.timer-fill.warn{background:linear-gradient(90deg,var(--gold),var(--gold2))}
.timer-fill.urgent{background:linear-gradient(90deg,var(--red),var(--red2));animation:pulse .5s ease infinite alternate}
@keyframes pulse{from{opacity:1}to{opacity:.7}}
.timer-num{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-family:'JetBrains Mono',monospace;font-weight:700;font-size:.85rem;color:white;text-shadow:0 1px 4px rgba(0,0,0,.5)}
.round-pill{background:var(--dark3);border:1px solid var(--gray3);padding:6px 14px;border-radius:999px;font-family:'JetBrains Mono',monospace;font-size:.8rem;color:var(--gray);white-space:nowrap}
.menu-btn-sm{background:var(--red);color:white;border:none;padding:6px 14px;border-radius:999px;font-family:'Outfit',sans-serif;font-weight:700;font-size:.78rem;cursor:pointer;white-space:nowrap}
.game-body{flex:1;display:grid;grid-template-columns:1fr 360px;overflow:hidden}
@media(max-width:900px){.game-body{grid-template-columns:1fr;grid-template-rows:1fr auto}}
.photo-area{position:relative;overflow:hidden;background:#111}
.photo-area img{width:100%;height:100%;object-fit:cover;transition:opacity .3s}
.photo-nav{position:absolute;top:50%;transform:translateY(-50%);width:48px;height:48px;border-radius:50%;background:rgba(0,0,0,.6);border:2px solid rgba(255,255,255,.3);color:white;font-size:1.3rem;display:grid;place-items:center;cursor:pointer;transition:all .2s;backdrop-filter:blur(8px)}
.photo-nav:hover{background:rgba(255,107,43,.7);border-color:var(--orange)}
.photo-nav.prev{left:14px}
.photo-nav.next{right:14px}
.photo-counter{position:absolute;top:14px;left:14px;background:rgba(0,0,0,.65);color:white;font-family:'JetBrains Mono',monospace;font-size:.72rem;padding:5px 12px;border-radius:999px;backdrop-filter:blur(8px)}
.info-panel{display:flex;flex-direction:column;background:var(--dark2);border-left:1px solid var(--gray3);overflow-y:auto}
@media(max-width:900px){.info-panel{border-left:none;border-top:1px solid var(--gray3);max-height:45vh}}
.map-wrap{height:220px;flex-shrink:0;border-bottom:1px solid var(--gray3)}
.map-wrap iframe{width:100%;height:100%;border:none;filter:brightness(90%) contrast(95%)}
.info-badges{display:flex;gap:8px;padding:14px 16px;flex-wrap:wrap;border-bottom:1px solid var(--gray3)}
.info-badge{padding:8px 16px;border-radius:12px;color:white;font-weight:800;font-size:.88rem}
.info-badge.surface{background:var(--blue)}
.info-badge.pieces{background:var(--blue)}
.info-badge.type{background:var(--orange);font-size:.78rem}
.info-details{padding:14px 16px;flex:1}
.info-city{font-weight:800;font-size:1.05rem;margin-bottom:2px}
.info-region{font-size:.8rem;color:var(--gray);margin-bottom:10px}
.info-desc{font-size:.82rem;color:var(--gray);line-height:1.55;border-top:1px solid var(--gray3);padding-top:10px}
.info-features{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px}
.info-feat{padding:4px 10px;border-radius:8px;background:var(--dark3);border:1px solid var(--gray3);font-size:.75rem;color:var(--gray)}
.players-strip{padding:10px 16px;border-top:1px solid var(--gray3);display:flex;flex-wrap:wrap;gap:6px}
.ps-player{display:flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;background:var(--dark3);border:1px solid var(--gray3);font-size:.75rem;font-weight:600}
.ps-player.done{border-color:rgba(34,197,94,.4);background:rgba(34,197,94,.1)}
.ps-player.current{border-color:var(--orange);background:var(--orange-bg)}
.ps-av{width:18px;height:18px;border-radius:6px;display:grid;place-items:center;font-size:.6rem;font-weight:900;color:white;flex-shrink:0}
.ps-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.ps-dot.w{background:var(--gray2)}
.ps-dot.d{background:var(--green)}
.bottom-bar{display:flex;align-items:center;gap:12px;padding:10px 16px;background:var(--dark2);border-top:2px solid var(--gray3);flex-shrink:0;z-index:10}
.estim-label{font-weight:700;font-size:.85rem;color:var(--gray);white-space:nowrap;display:none}
@media(min-width:700px){.estim-label{display:block}}
.estim-input-wrap{flex:1;display:flex;align-items:center;background:white;border-radius:12px;overflow:hidden;max-width:500px}
.estim-input{flex:1;padding:14px 18px;border:none;background:transparent;color:var(--dark);font-family:'Outfit',sans-serif;font-size:1.1rem;font-weight:700;outline:none}
.estim-input::placeholder{color:#bbb;font-weight:400}
.estim-euro{padding:0 16px;font-weight:900;font-size:1.1rem;color:var(--orange);background:rgba(255,107,43,.08)}
.estim-btn{padding:14px 32px;border-radius:12px;background:var(--red);color:white;border:none;font-family:'Outfit',sans-serif;font-weight:900;font-size:1rem;cursor:pointer;transition:all .2s;white-space:nowrap}
.estim-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(239,68,68,.4)}
.estim-btn:disabled{opacity:.3;cursor:not-allowed;transform:none}

/* ══ LOADING ══ */
.loading-overlay{position:fixed;inset:0;z-index:95;display:none;align-items:center;justify-content:center;flex-direction:column;gap:16px;background:rgba(0,0,0,.95);backdrop-filter:blur(20px)}
.loading-overlay.active{display:flex}
.loading-spinner{width:48px;height:48px;border:4px solid var(--gray3);border-top-color:var(--orange);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-weight:700;font-size:1rem;color:var(--gray)}

/* ══ OVERLAYS ══ */
.turn-overlay{position:fixed;inset:0;z-index:80;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,.92);backdrop-filter:blur(20px)}
.turn-overlay.active{display:flex}
.turn-box{text-align:center;animation:popIn .4s cubic-bezier(.34,1.56,.64,1)}
@keyframes popIn{from{opacity:0;transform:scale(.8)}to{opacity:1;transform:scale(1)}}
.turn-icon{font-size:3.5rem;margin-bottom:16px}
.turn-title{font-weight:900;font-size:1.8rem;margin-bottom:8px}
.turn-sub{font-size:.95rem;color:var(--gray);margin-bottom:24px}
.tbtn{padding:16px 40px;border-radius:14px;background:var(--orange);color:white;border:none;font-family:'Outfit',sans-serif;font-weight:900;font-size:1.1rem;cursor:pointer;transition:all .2s}
.tbtn:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(255,107,43,.4)}

.result-overlay{position:fixed;inset:0;z-index:85;display:none;flex-direction:column;align-items:center;justify-content:center;background:rgba(0,0,0,.95);backdrop-filter:blur(24px);overflow-y:auto;padding:30px 20px;gap:16px}
.result-overlay.active{display:flex}
.result-label{font-size:.9rem;color:var(--gray);opacity:0;animation:su .4s ease .1s forwards}
.result-price-big{font-weight:900;font-size:clamp(2.5rem,8vw,5rem);background:linear-gradient(135deg,var(--orange),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;opacity:0;animation:su .5s ease .3s forwards}
.result-grid{display:flex;flex-direction:column;gap:10px;max-width:500px;width:100%;margin-top:10px}
.rank-row{display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:14px;background:var(--dark2);border:1px solid var(--gray3);opacity:0;transform:translateX(-30px)}
.rank-row.gold{border-color:var(--gold);background:linear-gradient(135deg,rgba(251,191,36,.12),rgba(251,191,36,.03))}
.rank-pos{font-weight:900;font-size:1.3rem;width:32px;text-align:center;flex-shrink:0}
.rank-pos.p1{color:var(--gold)}.rank-pos.p2{color:#aaa}.rank-pos.p3{color:#cd7f32}
.rank-av{width:36px;height:36px;border-radius:10px;display:grid;place-items:center;font-weight:900;font-size:.85rem;color:white;flex-shrink:0}
.rank-info{flex:1;min-width:0}
.rank-name{font-weight:800;font-size:.9rem}
.rank-guess{font-size:.75rem;color:var(--gray);margin-top:2px}
.rank-diff{font-family:'JetBrains Mono',monospace;font-size:.78rem;font-weight:700}
.rank-diff.close{color:var(--green2)}.rank-diff.mid{color:var(--gold2)}.rank-diff.far{color:var(--red2)}
.rank-pts{font-weight:900;font-size:1rem;color:var(--gold);min-width:55px;text-align:right}
.result-continue{opacity:0;animation:su .4s ease 2.5s forwards;margin-top:14px}
@keyframes su{to{opacity:1;transform:translateX(0) translateY(0)}}

.final-overlay{position:fixed;inset:0;z-index:88;display:none;flex-direction:column;align-items:center;justify-content:center;background:rgba(0,0,0,.97);overflow-y:auto;padding:40px 20px;gap:16px}
.final-overlay.active{display:flex}
.confetti-wrap{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.confetti{position:absolute;width:8px;height:8px;border-radius:2px;opacity:0;animation:cf linear forwards}
@keyframes cf{0%{opacity:1;transform:translateY(-20px) rotate(0deg)}100%{opacity:0;transform:translateY(100vh) rotate(720deg)}}
.final-trophy{font-size:4rem;opacity:0;animation:su .5s ease .1s forwards}
.final-title{font-weight:900;font-size:clamp(1.5rem,5vw,2.5rem);text-align:center;opacity:0;animation:su .5s ease .2s forwards}
.final-sub{font-size:.9rem;color:var(--gray);opacity:0;animation:su .5s ease .3s forwards}
.podium{display:flex;align-items:flex-end;gap:12px;margin:20px 0}
.pod-item{display:flex;flex-direction:column;align-items:center;gap:6px;opacity:0}
.pod-bar{border-radius:14px 14px 0 0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:14px 18px;min-width:90px}
.pod-bar.p1{height:150px;background:linear-gradient(180deg,rgba(251,191,36,.25),rgba(251,191,36,.05));border:1px solid rgba(251,191,36,.4);border-bottom:none}
.pod-bar.p2{height:110px;background:linear-gradient(180deg,rgba(170,170,170,.15),rgba(170,170,170,.04));border:1px solid rgba(170,170,170,.3);border-bottom:none}
.pod-bar.p3{height:80px;background:linear-gradient(180deg,rgba(205,127,50,.15),rgba(205,127,50,.04));border:1px solid rgba(205,127,50,.3);border-bottom:none}
.pod-av{width:44px;height:44px;border-radius:12px;display:grid;place-items:center;font-weight:900;font-size:1rem;color:white}
.pod-name{font-weight:800;font-size:.85rem;text-align:center;max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pod-pts{font-weight:900;font-size:1.2rem;color:var(--gold)}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:3px}
</style>
</head>
<body>

<div id="menuScreen">
  <div class="menu-logo">🏠</div>
  <div class="menu-title">Estim'Immo</div>
  <div class="menu-sub">Des annonces immobilières <strong>générées par IA</strong> — uniques à chaque partie.<br>Devine le loyer mensuel — plus tu es proche, plus tu gagnes !</div>
  <div class="menu-modes">
    <div class="menu-mode" id="btnLocal"><div class="menu-mode-icon">📱</div><div class="menu-mode-title">Partie Locale</div><div class="menu-mode-sub">2–8 joueurs · 1 écran<br>6 manches · 30s/tour</div></div>
    <div class="menu-mode" id="btnOnline"><div class="menu-mode-icon">🌐</div><div class="menu-mode-title">En Ligne</div><div class="menu-mode-sub">Bientôt disponible</div></div>
  </div>
  <a href="index.html" style="color:var(--gray);font-size:.82rem;margin-top:12px;text-decoration:none">← Retour au Lobby</a>
</div>

<div id="setupScreen">
  <div class="setup-box">
    <div class="setup-title">🏠 Partie Locale</div>
    <div class="setup-sub">Ajoute 2 à 8 joueurs puis lance !</div>
    <div class="setup-input-row"><input class="setup-input" id="playerInput" type="text" placeholder="Nom du joueur..." maxlength="15"/><button class="sbtn sbtn-o" id="btnAdd">Ajouter</button></div>
    <div class="player-chips" id="chips"></div>
    <button class="sbtn sbtn-o sbtn-big" id="btnStart" disabled>🏠 Lancer la partie →</button>
    <button class="sbtn sbtn-g sbtn-big" onclick="showMenu()">← Retour</button>
  </div>
</div>

<div id="gameScreen">
  <div class="top-bar">
    <div class="score-pill" id="scorePill">0 Pts</div>
    <div class="timer-wrap"><div class="timer-fill" id="timerFill" style="width:100%"><div class="timer-num" id="timerNum">30</div></div></div>
    <div class="round-pill" id="roundPill">1 / 6</div>
    <button class="menu-btn-sm" id="btnQuit">MENU</button>
  </div>
  <div class="game-body">
    <div class="photo-area">
