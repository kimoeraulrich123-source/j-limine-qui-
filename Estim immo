    </div>
  </div>
  <div class="bottom-bar">
    <span class="estim-label" id="eLabel">Votre estimation</span>
    <div class="estim-input-wrap"><input class="estim-input" id="eInput" type="number" placeholder="Votre estimation" min="0" max="50000" step="10"/><div class="estim-euro">€</div></div>
    <button class="estim-btn" id="btnVal">Valider</button>
  </div>
</div>

<div class="loading-overlay" id="loadingOv"><div class="loading-spinner"></div><div class="loading-text" id="loadingTxt">Génération de l'annonce par IA...</div></div>
