async function generateListing(cityData){
  const prompt=`Tu es un expert immobilier. Génère UNE annonce de location RÉALISTE pour la ville suivante : ${cityData.city} (${cityData.region}).

Réponds UNIQUEMENT en JSON valide, sans markdown, sans backticks, sans texte avant/après. Format exact :
{"type":"Appartement ou Maison","title":"titre court 3-5 mots","surface":nombre_m2,"pieces":nombre_pieces,"price":loyer_mensuel_euros_réaliste_2025,"desc":"description 2 phrases max","features":["feat1","feat2","feat3","feat4"]}

IMPORTANT : le prix doit être RÉALISTE pour cette ville en 2025. Varie les surfaces (15-120m²), les types, les prix. Sois créatif dans les descriptions.`;

  try{
    const resp=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({
        model:"claude-sonnet-4-20250514",
        max_tokens:300,
        messages:[{role:"user",content:prompt}]
      })
    });
    const data=await resp.json();
    const text=data.content?.[0]?.text||'';
    // Parse JSON from response
    const clean=text.replace(/```json|```/g,'').trim();
    const listing=JSON.parse(clean);
    return{
      ...listing,
      city:cityData.city,
      region:cityData.region,
      lat:cityData.lat,
      lng:cityData.lng,
      photos:getPhotos()
    };
  }catch(e){
    console.error('AI generation failed:',e);
    // Fallback: generate a random listing locally
    return generateFallback(cityData);
  }
}

function generateFallback(cd){
  const types=[
    {t:"Appartement",s:[18,25,30,35,42,50,55,65,75,85],p:[1,1,1,2,2,2,3,3,4,4]},
    {t:"Maison",s:[70,85,95,110,120],p:[3,4,4,5,5]}
  ];
  const pick=types[cd.region.includes('Réunion')?Math.floor(Math.random()*2):0];
  const idx=Math.floor(Math.random()*pick.s.length);
  const surface=pick.s[idx];const pieces=pick.p[idx];
  // Price per m2 estimates
  const priceMap={'Île-de-France':28,'PACA':16,'Auvergne-Rhône-Alpes':15,'Nouvelle-Aquitaine':13,'Occitanie':13,'Hauts-de-France':12,'Pays de la Loire':13,'Grand Est':12,'Bretagne':12,'Normandie':11,'La Réunion (974)':13};
  let pm2=priceMap[cd.region]||12;
  // Variance ±30%
  pm2*=(0.7+Math.random()*0.6);
  const price=Math.round(surface*pm2/10)*10;
  const descs=['Lumineux et calme, proche commerces.','Rénové récemment, belle prestation.','Charmant bien de caractère.','Idéalement situé, bien entretenu.','Vue dégagée, résidence sécurisée.'];
  const feats=[['Lumineux','Calme','Cuisine équipée','Cave'],['Rénové','Parquet','Ascenseur','Digicode'],['Vue dégagée','Balcon','Parking','Gardien'],['Climatisé','Varangue','Résidence calme','Proche bus'],['Meublé','Proche fac','Kitchenette','Douche']];
  const fi=Math.floor(Math.random()*feats.length);
  return{type:pick.t,title:`${pick.t} ${pieces}p ${surface}m²`,surface,pieces,price,desc:descs[fi],features:feats[fi],city:cd.city,region:cd.region,lat:cd.lat,lng:cd.lng,photos:getPhotos()};
}

// ══ STATE ══
let G={players:[],round:0,listings:[],cur:null,estimates:{},pidx:0,pIdx:0,timer:null,timerEnd:0,scores:{},cities:[]};

function showMenu(){$('menuScreen').style.display='flex';$('setupScreen').classList.remove('active');$('gameScreen').classList.remove('active');}
function showSetup(){$('menuScreen').style.display='none';$('setupScreen').classList.add('active');}
function showGame(){$('menuScreen').style.display='none';$('setupScreen').classList.remove('active');$('gameScreen').classList.add('active');}
function backToMenu(){$('finalOv').classList.remove('active');$('resultOv').classList.remove('active');G={players:[],round:0,listings:[],cur:null,estimates:{},pidx:0,pIdx:0,timer:null,timerEnd:0,scores:{},cities:[]};players=[];renderChips();$('btnStart').disabled=true;showMenu();}
window.showMenu=showMenu;window.backToMenu=backToMenu;

// ══ SETUP ══
let players=[];
$('btnLocal').onclick=showSetup;
$('btnOnline').onclick=()=>alert('Mode en ligne bientôt disponible !');
$('btnAdd').onclick=addP;
$('playerInput').onkeydown=e=>{if(e.key==='Enter')addP();};
function addP(){const inp=$('playerInput');const n=(inp.value||'').trim();if(!n||players.length>=8)return;if(players.some(p=>p.toLowerCase()===n.toLowerCase()))return;players.push(n);inp.value='';inp.focus();renderChips();$('btnStart').disabled=players.length<2;}
function removeP(i){players.splice(i,1);renderChips();$('btnStart').disabled=players.length<2;}
window.removeP=removeP;
function renderChips(){$('chips').innerHTML=players.map((p,i)=>`<div class="player-chip"><span class="ps-av" style="background:${avC(p)}">${avI(p)}</span>${esc(p)}<span class="x" onclick="removeP(${i})">✕</span></div>`).join('')||'<span style="color:#555;font-size:.82rem">Ajoute au moins 2 joueurs</span>';}
renderChips();

$('btnStart').onclick=async()=>{
  if(players.length<2)return;
  G.players=players.map((n,i)=>({name:n,id:'p'+i}));
  G.scores={};G.players.forEach(p=>G.scores[p.id]=0);
  G.round=0;
  // Pick 6 random cities (no repeat)
  G.cities=shuffle(CITIES_POOL).slice(0,ROUNDS);
  G.listings=[];
  showGame();
  // Pre-generate first listing
  await startRound();
};

// ══ GAME ══
async function startRound(){
  G.round++;
  if(G.round>ROUNDS){showFinal();return;}
  G.estimates={};G.pidx=0;G.pIdx=0;
  $('roundPill').textContent=G.round+' / '+ROUNDS;
  // Show loading while AI generates
  $('loadingOv').classList.add('active');
  $('loadingTxt').textContent=`Génération de l'annonce ${G.round}/${ROUNDS}...`;
  try{
    const listing=await generateListing(G.cities[G.round-1]);
    G.cur=listing;
  }catch(e){
    G.cur=generateFallback(G.cities[G.round-1]);
  }
  $('loadingOv').classList.remove('active');
  renderAnnonce();renderMap();renderPlayers();
  showTurn(0);
}

function renderAnnonce(){
  const l=G.cur;
  $('photoImg').src=l.photos[0];G.pIdx=0;
  $('photoCtr').textContent='1 / '+l.photos.length;
  $('badges').innerHTML=`<div class="info-badge surface">${l.surface} m²</div><div class="info-badge pieces">${l.pieces} pièce${l.pieces>1?'s':''}</div><div class="info-badge type">${esc(l.type)}</div>`;
  $('iCity').textContent=l.city;
  $('iRegion').textContent=l.region;
  $('iFeats').innerHTML=(l.features||[]).map(f=>`<span class="info-feat">${esc(f)}</span>`).join('');
  $('iDesc').textContent=l.desc||'';
}
function renderMap(){
  const l=G.cur;
  $('mapFrame').src=`https://www.openstreetmap.org/export/embed.html?bbox=${l.lng-.012},${l.lat-.007},${l.lng+.012},${l.lat+.007}&layer=mapnik&marker=${l.lat},${l.lng}`;
}
$('pPrev').onclick=()=>{G.pIdx=(G.pIdx-1+G.cur.photos.length)%G.cur.photos.length;updP();};
$('pNext').onclick=()=>{G.pIdx=(G.pIdx+1)%G.cur.photos.length;updP();};
function updP(){$('photoImg').src=G.cur.photos[G.pIdx];$('photoCtr').textContent=(G.pIdx+1)+' / '+G.cur.photos.length;}
function renderPlayers(){$('pStrip').innerHTML=G.players.map(p=>{const done=p.id in G.estimates;const cur=G.players[G.pidx]?.id===p.id&&!done;return`<div class="ps-player ${done?'done':''} ${cur?'current':''}"><span class="ps-av" style="background:${avC(p.name)}">${avI(p.name)}</span>${esc(p.name)}<span class="ps-dot ${done?'d':'w'}"></span></div>`;}).join('');}

function showTurn(idx){if(idx>=G.players.length){showResult();return;}G.pidx=idx;renderPlayers();const p=G.players[idx];$('tTitle').textContent=p.name+', c\'est ton tour !';$('tSub').textContent='Regarde l\'annonce et estime le loyer mensuel';$('turnOv').classList.add('active');$('btnReady').onclick=()=>{$('turnOv').classList.remove('active');startEstim(idx);};}
function startEstim(idx){const p=G.players[idx];$('eLabel').textContent=p.name;$('scorePill').textContent=G.scores[p.id]+' Pts';$('eInput').value='';$('eInput').disabled=false;$('btnVal').disabled=false;$('eInput').focus();startTimer();}
function startTimer(){clearInterval(G.timer);G.timerEnd=Date.now()+TIMER*1000;G.timer=setInterval(()=>{const ms=Math.max(0,G.timerEnd-Date.now());const s=Math.ceil(ms/1000);const pct=(ms/(TIMER*1000))*100;const f=$('timerFill');f.style.width=pct+'%';$('timerNum').textContent=s;f.className='timer-fill'+(s<=5?' urgent':s<=10?' warn':'');if(ms<=0){clearInterval(G.timer);doSubmit(null);}},80);}
$('btnVal').onclick=()=>{const v=parseInt($('eInput').value);if(isNaN(v)||v<0)return;doSubmit(v);};
$('eInput').onkeydown=e=>{if(e.key==='Enter')$('btnVal').click();};
function doSubmit(val){clearInterval(G.timer);$('eInput').disabled=true;$('btnVal').disabled=true;G.estimates[G.players[G.pidx].id]=val??0;renderPlayers();setTimeout(()=>showTurn(G.pidx+1),500);}

// ══ RESULT with proportional scoring ══
function showResult(){
  const real=G.cur.price;
  $('rPrice').textContent=real+' €/mois';
  const ranked=G.players.map(p=>{
    const g=G.estimates[p.id]||0;
    const diff=Math.abs(g-real);
    const pctOff=real>0?diff/real:1;
    const pts=calcPoints(g,real);
    return{...p,guess:g,diff,pctOff,pts};
  }).sort((a,b)=>a.diff-b.diff);
  // Apply points
  ranked.forEach(r=>G.scores[r.id]+=r.pts);
  $('rGrid').innerHTML=ranked.map((r,i)=>{
    const d=.5+i*.3;
    const pctLabel=Math.round(r.pctOff*100);
    const cls=pctLabel<10?'close':pctLabel<25?'mid':'far';
    return`<div class="rank-row ${i===0?'gold':''}" style="animation:su .5s cubic-bezier(.34,1.56,.64,1) ${d}s forwards"><span class="rank-pos p${i+1}">#${i+1}</span><div class="rank-av" style="background:${avC(r.name)}">${avI(r.name)}</div><div class="rank-info"><div class="rank-name">${esc(r.name)}</div><div class="rank-guess">Estimation : ${r.guess} € (${pctLabel}% d'écart)</div></div><span class="rank-diff ${cls}">Δ ${r.diff} €</span><span class="rank-pts">+${r.pts}</span></div>`;
  }).join('');
  $('btnNext').textContent=G.round>=ROUNDS?'Voir les résultats →':'Manche suivante →';
  // Reset animations
  $('resultOv').querySelectorAll('[style*="animation"]').forEach(el=>{el.style.animation='none';el.offsetHeight;el.style.animation='';});
  $('resultOv').classList.add('active');
}
$('btnNext').onclick=async()=>{$('resultOv').classList.remove('active');await startRound();};

// ══ FINAL ══
function showFinal(){
  const sorted=G.players.map(p=>({...p,score:G.scores[p.id]})).sort((a,b)=>b.score-a.score);
  $('fTitle').textContent='🏆 '+sorted[0].name+' remporte la partie !';
  $('fSub').textContent=ROUNDS+' manches · '+G.players.length+' joueurs';
  const pod=sorted.length>=3?[sorted[1],sorted[0],sorted[2]]:sorted.length>=2?[sorted[1],sorted[0]]:sorted;
  const pos=sorted.length>=3?[2,1,3]:sorted.length>=2?[2,1]:[1];
  $('podium').innerHTML=pod.map((p,i)=>{const ps=pos[i];const d=.3+ps*.3;return`<div class="pod-item" style="animation:su .6s cubic-bezier(.34,1.56,.64,1) ${d}s forwards"><div class="pod-av" style="background:${avC(p.name)}">${avI(p.name)}</div><div class="pod-name">${esc(p.name)}</div><div class="pod-bar p${ps}"><div class="pod-pts">${p.score}</div><div style="font-size:.7rem;color:#888;margin-top:4px">#${ps}</div></div></div>`;}).join('');
  $('fExtra').innerHTML=sorted.slice(3).map((p,i)=>`<div class="rank-row" style="animation:su .4s ease ${1.5+i*.2}s forwards"><span class="rank-pos">#${i+4}</span><div class="rank-av" style="background:${avC(p.name)}">${avI(p.name)}</div><div class="rank-info"><div class="rank-name">${esc(p.name)}</div></div><span class="rank-pts">${p.score} pts</span></div>`).join('');
  const cw=$('confWrap');cw.innerHTML='';const cols=['#ff6b2b','#fbbf24','#22c55e','#3b82f6','#ec4899','#7c3aed'];
  for(let i=0;i<80;i++){const e=document.createElement('div');e.className='confetti';e.style.cssText=`left:${Math.random()*100}%;background:${cols[i%cols.length]};animation-duration:${1.2+Math.random()*2}s;animation-delay:${Math.random()}s;width:${5+Math.random()*8}px;height:${5+Math.random()*8}px;border-radius:${Math.random()>.5?'50%':'2px'}`;cw.appendChild(e);}
  $('finalOv').classList.add('active');
}
$('btnQuit').onclick=()=>{if(confirm('Quitter ?'))backToMenu();};
</script>
